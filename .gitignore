# ===========================================================================
# SecureStack Root GitIgnore
# Prevents sensitive credentials, environment variables, local states,
# and build artifacts from being exposed on GitHub.
# ===========================================================================

# Environment Variables & Private Credentials
.env
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.pub
aws-creds*
credentials*
credentials.json
client_secret*.json
secrets.json
.aws/

# Terraform Local States & Private Variables
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
crash.log

# IDE & Editor Configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Build & Lambdas Packaging Artifacts
.build/
.aws-sam/
*.zip
*.tar.gz
*.egg
*.egg-info/
dist/
build/

# Python Virtual Environments & Caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv/
venv/
env/
ENV/
.env-py/
.ipynb_checkpoints/
.python-version

# Next.js / Frontend Node Modules & Caches
**/node_modules/
**/.next/
**/out/
**/.vercel
next-env.d.ts
*.tsbuildinfo

# Logs & Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
